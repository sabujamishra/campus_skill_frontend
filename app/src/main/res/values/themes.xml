<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Hinglish: App ki global styling) -->
    <style name="Base.Theme.CampusSkill" parent="Theme.Material3.Light.NoActionBar">
        <!-- Brand colors yahan set kiye hain -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorSecondary">@color/accent_teal</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Input fields ki specific styling -->
        <item name="textInputStyle">@style/CustomTextInputLayout</item>
        <item name="editTextStyle">@style/CustomEditText</item>
    </style>

    <!-- Outlined input box ki customized settings -->
    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/text_grey</item>
    </style>

    <!-- Input text (Jo user type karta hai) ki styling -->
    <style name="CustomEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textColorHighlight">#402196F3</item>
    </style>

    <style name="Theme.CampusSkill" parent="Base.Theme.CampusSkill" />

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedTopCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="CategoryChip" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:textColor">@color/text_grey</item>
        <item name="android:textSize">14sp</item>
        <item name="android:background">@drawable/bg_tag_rounded</item>
    </style>

    <style name="CategoryChipActive" parent="CategoryChip">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/bg_price_pill</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="RoundedTopRight">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomRight">16dp</item>
        <item name="cornerSizeBottomLeft">2dp</item>
    </style>

    <style name="RoundedTopLeft">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">16dp</item>
        <item name="cornerSizeBottomRight">2dp</item>
    </style>

    <style name="CustomDialogTheme" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="colorBackgroundFloating">@android:color/transparent</item>
    </style>

    <style name="BottomNavTheme" parent="Widget.Material3.BottomNavigationView">
        <item name="colorSecondaryContainer">#E3F2FD</item>
        <item name="colorOnSecondaryContainer">@color/button_blue</item>
    </style>
</resources>