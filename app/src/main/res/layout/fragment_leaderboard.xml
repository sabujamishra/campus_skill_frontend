<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Global Rankings"
                android:textColor="@color/text_main"
                android:textSize="28sp"
                android:textStyle="bold" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@android:color/transparent"
                app:tabIndicatorColor="@color/primary"
                app:tabIndicatorGravity="bottom"
                app:tabIndicatorFullWidth="false"
                app:tabSelectedTextColor="@color/primary"
                app:tabTextColor="@color/text_grey"
                app:tabMode="fixed"
                app:tabRippleColor="@android:color/transparent">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Earners" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top Rated" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Most Active" />
            </com.google.android.material.tabs.TabLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Podium (Top 3 Users) -->
            <RelativeLayout
                android:id="@+id/layoutPodium"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <!-- 2nd Place (Left) -->
                <LinearLayout
                    android:id="@+id/podium2"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_toStartOf="@+id/podium1"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivPodium2"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/ic_profile"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeWidth="3dp"
                        app:strokeColor="#C0C0C0" />

                    <TextView
                        android:id="@+id/tvPodiumName2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="User"
                        android:gravity="center"
                        android:textColor="@color/text_main"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPodiumValue2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 pts"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 1st Place (Center - Highlighted) -->
                <LinearLayout
                    android:id="@+id/podium1"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentBottom="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivPodium1"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@drawable/ic_profile"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeWidth="4dp"
                        app:strokeColor="@color/accent_orange" />

                    <TextView
                        android:id="@+id/tvPodiumName1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="Winner"
                        android:gravity="center"
                        android:textColor="@color/text_main"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPodiumValue1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 pts"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 3rd Place (Right) -->
                <LinearLayout
                    android:id="@+id/podium3"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_toEndOf="@+id/podium1"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivPodium3"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_profile"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeWidth="3dp"
                        app:strokeColor="#CD7F32" />

                    <TextView
                        android:id="@+id/tvPodiumName3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="User"
                        android:gravity="center"
                        android:textColor="@color/text_main"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPodiumValue3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 pts"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </RelativeLayout>

            <!-- List Separator -->
            <TextView
                android:id="@+id/tvOthersTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Rankings"
                android:textColor="@color/text_light"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layoutEmptyLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_profile"
                    app:tint="@color/divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Loading rankings..."
                    android:textColor="@color/text_grey"
                    android:textSize="16sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
